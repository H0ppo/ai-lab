# ---------------------------------------------------------------------------
# AI Runtime Security Demo — environment defaults.
# Copy to .env.local and adjust. Most day-to-day config is done in the
# in-app Setup Wizard / Settings (persisted to setup.json), so this file can
# stay almost empty.
# ---------------------------------------------------------------------------

APP_DEMO_NAME=AI Runtime Security Demo

# --- Server -----------------------------------------------------------------
# Bind to all interfaces so the app is reachable on the host IP (NOT localhost).
HOST=0.0.0.0
PORT=5000
UI_THEME=dark

# --- Ollama (EXTERNAL — this app does not install or bundle Ollama) ---------
# Leave blank to be prompted in the Setup Wizard. Examples:
#   OLLAMA_URL=http://192.168.1.50:11434      (Ollama on another machine)
#   OLLAMA_URL=http://host.docker.internal:11434  (Ollama on the Docker host)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2:1b

# --- Optional cloud providers ----------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEFAULT_PROVIDER=ollama

# --- Zscaler AI Guard (optional) -------------------------------------------
ZS_GUARDRAILS_ENABLED=false
ZS_GUARDRAILS_MODE=das
ZS_GUARDRAILS_URL=https://api.zseclipse.net/v1/detection/resolve-and-execute-policy
ZS_GUARDRAILS_API_KEY=
ZS_GUARDRAILS_TIMEOUT_SECONDS=15
ZS_PROXY_BASE_URL=https://proxy.zseclipse.net

# --- Agentic / tools --------------------------------------------------------
AGENTIC_MAX_STEPS=3
MULTI_AGENT_MAX_SPECIALIST_ROUNDS=1
MAX_TOOLS_IN_REQUEST=20
LOCAL_TASKS_BASE_DIR=demo_local_workspace

# --- Config access ----------------------------------------------------------
# Config/settings are reachable from the host IP (not localhost-restricted).
# Set ADMIN_TOKEN to require an X-Admin-Token header to SAVE config.
CONFIG_ALLOW_REMOTE=true
ADMIN_TOKEN=
